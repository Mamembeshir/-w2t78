# =============================================================================
# Warehouse Intelligence & Offline Crawling Operations Platform
# Environment Variables
#
# SETUP:
#   cp .env.example .env
#   Then fill in every CHANGE_ME value before starting the stack.
#
# NEVER commit the real .env file — it is listed in .gitignore.
# =============================================================================

# -----------------------------------------------------------------------------
# Django Application
# -----------------------------------------------------------------------------
# Generate with:
#   python -c "import secrets; print(secrets.token_urlsafe(64))"
DJANGO_SECRET_KEY=CHANGE_ME_replace_with_a_random_string_of_at_least_50_characters

DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,backend,0.0.0.0

# Timezone for wall-clock digest scheduling ("6:00 PM" in SPEC means 6 PM here).
# Default: UTC. Set to e.g. "America/New_York" for US Eastern warehouses.
TIME_ZONE=UTC

# Self-registration: set to "true" to allow new Procurement Analyst sign-ups.
REGISTRATION_OPEN=false

# -----------------------------------------------------------------------------
# Database (MySQL 8)
# -----------------------------------------------------------------------------
MYSQL_ROOT_PASSWORD=CHANGE_ME_root_password
DB_HOST=db
DB_PORT=3306
DB_NAME=warehouse_db
DB_USER=warehouse_user
DB_PASSWORD=CHANGE_ME_db_password

# MySQL Docker env vars (must match DB_* above)
MYSQL_DATABASE=warehouse_db
MYSQL_USER=warehouse_user
MYSQL_PASSWORD=CHANGE_ME_db_password

# -----------------------------------------------------------------------------
# Redis / Celery
# -----------------------------------------------------------------------------
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

# -----------------------------------------------------------------------------
# Field Encryption (django-encrypted-model-fields)
#
# Generate a new key with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
#
# WARNING: losing this key makes all encrypted fields (API keys, crawl headers,
# supplier credentials) permanently unreadable. Store it in a secrets manager.
# -----------------------------------------------------------------------------
FIELD_ENCRYPTION_KEY=CHANGE_ME_generate_with_python_cmd_shown_above

# -----------------------------------------------------------------------------
# CORS (Frontend origin allowed to call the API)
# -----------------------------------------------------------------------------
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# -----------------------------------------------------------------------------
# Frontend (Vite)
# -----------------------------------------------------------------------------
VITE_API_BASE_URL=http://localhost:8000

# -----------------------------------------------------------------------------
# Optional: Local SMTP Gateway (leave blank if not present)
# Notifications queue in-app and send via this relay when configured.
# -----------------------------------------------------------------------------
SMTP_HOST=
SMTP_PORT=25
SMTP_USE_TLS=False

# -----------------------------------------------------------------------------
# Optional: Local SMS Gateway (leave blank if not present)
# POST requests sent to this URL when configured.
# -----------------------------------------------------------------------------
SMS_GATEWAY_URL=
