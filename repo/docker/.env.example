# =============================================================================
# Warehouse Intelligence & Offline Crawling Operations Platform
# Environment Variables — copy this file to ../.env (repo root) and fill in
# NEVER commit the real .env file
# =============================================================================

# -----------------------------------------------------------------------------
# Django Application
# -----------------------------------------------------------------------------
DJANGO_SECRET_KEY=changeme-replace-with-a-long-random-string-min-50-chars
DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,backend,0.0.0.0

# -----------------------------------------------------------------------------
# Database (MySQL 8)
# -----------------------------------------------------------------------------
MYSQL_ROOT_PASSWORD=rootpassword_change_me
DB_HOST=db
DB_PORT=3306
# Host-side ports (mapped in docker-compose): MySQL→3307, Redis→6380 to avoid conflicts
DB_NAME=warehouse_db
DB_USER=warehouse_user
DB_PASSWORD=warehouse_pass_change_me

# MySQL Docker env vars (must match DB_* above)
MYSQL_DATABASE=warehouse_db
MYSQL_USER=warehouse_user
MYSQL_PASSWORD=warehouse_pass_change_me

# -----------------------------------------------------------------------------
# Redis / Celery
# -----------------------------------------------------------------------------
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

# -----------------------------------------------------------------------------
# Field Encryption (django-encrypted-model-fields)
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Used to encrypt: supplier API keys, crawl rule secrets, request headers with credentials
# -----------------------------------------------------------------------------
FIELD_ENCRYPTION_KEY=your-fernet-base64-encoded-32-byte-key-here

# -----------------------------------------------------------------------------
# CORS (Frontend origin allowed to call the API)
# -----------------------------------------------------------------------------
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# -----------------------------------------------------------------------------
# Frontend (Vite)
# -----------------------------------------------------------------------------
VITE_API_BASE_URL=http://localhost:8000

# -----------------------------------------------------------------------------
# Optional: Local SMTP Gateway (leave blank if not present)
# Notifications queue in-app and send via this relay when configured.
# -----------------------------------------------------------------------------
SMTP_HOST=
SMTP_PORT=25
SMTP_USE_TLS=False

# -----------------------------------------------------------------------------
# Optional: Local SMS Gateway (leave blank if not present)
# POST requests sent to this URL when configured.
# -----------------------------------------------------------------------------
SMS_GATEWAY_URL=
